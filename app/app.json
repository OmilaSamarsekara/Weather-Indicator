{
  "expo": {
    "name": "WeatherApp",
    "slug": "weather-app",
    "scheme": "weatherapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/app-icon.png",
    "splash": {
      "image": "./assets/icons/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b1021"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.code.weatherapp",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "INTERNET"
      ]
    },
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
